# Preserve SEO: 301-redirect the old .php URLs to the new static pages.
RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^(index|about|services|products|team|portfolio|contact|faq|price|sitemap|b2b-development|b2c-development|custom-website|professional-website|cms|ecommerce|mobile-apps|mobile-friendly|mobile-ui|test-automation|manual-testing|performance-testing|software-validation|load-testing|tools-expertise|seo|web-api)\.php$ /$1.html [R=301,L]

# Removed pages (blog and old-template demo pages): send old URLs to the
# closest live page instead of a 404.
RewriteRule ^(blog|blog-single)\.(php|html)$ /index.html [R=301,L]
RewriteRule ^price-layouts\.(php|html)$ /price.html [R=301,L]
RewriteRule ^(elements|headings|column)\.(php|html)$ /index.html [R=301,L]

ErrorDocument 404 /404.html
