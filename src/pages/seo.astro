---
import ThemeLayout from '../layouts/ThemeLayout.astro';
---
<ThemeLayout page="services" heading="Search Engine Optimization">

  <section class="inner-page padd-section">
    <div class="container">

      <div class="row align-items-center mb-5" data-aos="fade-up">
        <div class="col-md-2 col-sm-12 text-center mb-4 mb-md-0">
          <div class="svc-hero-icon">
            <i class="fa fa-search"></i>
          </div>
        </div>
        <div class="col-md-10">
          <h3>Get Found by the Right Audience</h3>
          <p>Rayinfos Technologies delivers cost-effective SEO services for businesses of all sizes — increasing website visibility, driving quality organic traffic, generating new sales leads and delivering efficient returns on your investment through proven, white-hat techniques.</p>
        </div>
      </div>

      <div class="row" data-aos="fade-up" data-aos-delay="100">
        <div class="col-md-6 col-lg-4">
          <div class="svc-card">
            <div class="svc-card-icon"><i class="fa fa-key"></i></div>
            <h5>Keyword Analysis</h5>
            <p>Identify the most effective keywords by analysing visitor search patterns across the internet to target the right audience.</p>
          </div>
        </div>
        <div class="col-md-6 col-lg-4">
          <div class="svc-card">
            <div class="svc-card-icon"><i class="fa fa-file-code-o"></i></div>
            <h5>Page Optimisation</h5>
            <p>Increase search engine visibility by optimising web page content, meta tags, URLs and site structure for maximum ranking.</p>
          </div>
        </div>
        <div class="col-md-6 col-lg-4">
          <div class="svc-card">
            <div class="svc-card-icon"><i class="fa fa-link"></i></div>
            <h5>Link Building</h5>
            <p>Effective link-building campaigns to generate quality back-links that boost your site's authority and search engine ranking.</p>
          </div>
        </div>
        <div class="col-md-6 col-lg-4">
          <div class="svc-card">
            <div class="svc-card-icon"><i class="fa fa-binoculars"></i></div>
            <h5>Competitive Analysis</h5>
            <p>Complete SWOT analysis of your competition to identify where your business stands and opportunities to outperform rivals.</p>
          </div>
        </div>
        <div class="col-md-6 col-lg-4">
          <div class="svc-card">
            <div class="svc-card-icon"><i class="fa fa-pencil"></i></div>
            <h5>Content Development</h5>
            <p>Develop and modify website content with effective keywords — making every page both reader-friendly and SEO-ready.</p>
          </div>
        </div>
        <div class="col-md-6 col-lg-4">
          <div class="svc-card">
            <div class="svc-card-icon"><i class="fa fa-bar-chart"></i></div>
            <h5>Monthly Reports</h5>
            <p>Regular keyword analysis, initial and monthly ranking, and comparative position analysis reports keep you informed at every step.</p>
          </div>
        </div>
      </div>

    </div>
  </section>

</ThemeLayout>
