---
import ThemeLayout from '../layouts/ThemeLayout.astro';
---
<ThemeLayout page="404" heading="Page Not Found">

  <section class="inner-page padd-section text-center">
    <div class="container" data-aos="fade-up">
      <div class="section-title text-center">
        <h2>Error 404</h2>
        <p class="separator">The page you are looking for doesn't exist or has been moved.</p>
      </div>

      <img src="images/404-error.png" alt="Page not found" class="img-fluid mb-4">
      <p>Check the address for typos, or head back to the home page — everything we offer is one click away from there.</p>
      <p><a href="index.html" class="btn-get-started">Back to Home</a></p>
    </div>
  </section>

</ThemeLayout>
