---
import ThemeLayout from '../layouts/ThemeLayout.astro';
---
<ThemeLayout page="services" heading="Ecommerce Solutions">

  <section class="inner-page padd-section">
    <div class="container">

      <div class="row align-items-center mb-5" data-aos="fade-up">
        <div class="col-md-2 col-sm-12 text-center mb-4 mb-md-0">
          <div class="svc-hero-icon">
            <i class="fa fa-credit-card"></i>
          </div>
        </div>
        <div class="col-md-10">
          <h3>Comprehensive Online Store Development</h3>
          <p>Rayinfos Technologies specializes in advanced eCommerce solutions — from small stores to large virtual malls — with integrated payment gateways, shopping carts and CMS, all with complete security for you and your customers worldwide.</p>
        </div>
      </div>

      <div class="row" data-aos="fade-up" data-aos-delay="100">
        <div class="col-md-6 col-lg-4">
          <div class="svc-card">
            <div class="svc-card-icon"><i class="fa fa-credit-card"></i></div>
            <h5>Payment Gateway</h5>
            <p>Integrated payment gateway and credit card processing supporting multiple payment methods for a seamless checkout experience.</p>
          </div>
        </div>
        <div class="col-md-6 col-lg-4">
          <div class="svc-card">
            <div class="svc-card-icon"><i class="fa fa-shopping-cart"></i></div>
            <h5>Shopping Cart</h5>
            <p>User-friendly shopping cart with easy checkout, order tracking and inventory management to keep your store running smoothly.</p>
          </div>
        </div>
        <div class="col-md-6 col-lg-4">
          <div class="svc-card">
            <div class="svc-card-icon"><i class="fa fa-exchange"></i></div>
            <h5>Order Management</h5>
            <p>Online exchange of orders, inquiries, invoices and funds — all managed through a secure, centralised eCommerce platform.</p>
          </div>
        </div>
        <div class="col-md-6 col-lg-4">
          <div class="svc-card">
            <div class="svc-card-icon"><i class="fa fa-lock"></i></div>
            <h5>Security &amp; Trust</h5>
            <p>Complete security for you and your customers worldwide — SSL, encrypted data and secure payment flows built in from the ground up.</p>
          </div>
        </div>
        <div class="col-md-6 col-lg-4">
          <div class="svc-card">
            <div class="svc-card-icon"><i class="fa fa-search"></i></div>
            <h5>SEO &amp; Marketing</h5>
            <p>Search engine optimisation and marketing strategies integrated into your store to drive organic traffic and enhance conversions.</p>
          </div>
        </div>
        <div class="col-md-6 col-lg-4">
          <div class="svc-card">
            <div class="svc-card-icon"><i class="fa fa-bar-chart"></i></div>
            <h5>Analytics &amp; Reporting</h5>
            <p>Tracking and reporting web traffic, sales leads and customer behaviour to help you make data-driven business decisions.</p>
          </div>
        </div>
      </div>

    </div>
  </section>

</ThemeLayout>
