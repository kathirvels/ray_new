---
import ThemeLayout from '../layouts/ThemeLayout.astro';

const products = [
  {
    icon: 'images/icons/service-icon-1.png',
    title: 'Best Email Tool',
    text: 'Fast and flexible bulk email creator — the easy way to build and send email campaigns for your business. Send ads, request business, or build loyalty, trust and brand awareness with your current or potential customers.',
  },
  {
    icon: 'images/icons/help.png',
    title: 'Help Desk',
    text: 'A resource intended to provide your customers with information and support related to your products and services — troubleshooting and guidance through toll-free numbers, websites, instant messaging, or email.',
  },
  {
    icon: 'images/icons/crm.png',
    title: 'CRM',
    text: "Customer relationship management (CRM) is a model for managing a company's interactions with current and future customers, using technology to organize, automate, and synchronize sales, marketing, customer service, and technical support.",
  },
  {
    icon: 'images/icons/service-icon-4.png',
    title: 'E-Commerce',
    text: 'Ready to start e-commerce and enjoy all the advantages brought by it? B2B or B2C — no matter which one you select, we can provide you with our top-quality e-commerce solution.',
  },
  {
    icon: 'images/icons/service-icon-2.png',
    title: 'Find My Food',
    text: 'Powerful, stylish and modern food (restaurant) finding portal which helps you select healthy food.',
  },
  {
    icon: 'images/icons/survey.png',
    title: 'Survey',
    text: 'Build statistical surveys for making inferences about the population being studied — public opinion polls, public health surveys, market research surveys and censuses, all powered by contemporary survey methodology.',
  },
  {
    icon: 'images/icons/service-icon-6.png',
    title: 'Live Chat',
    text: 'Online chat application designed specifically for businesses or organizations to provide online assistance to website visitors in real time.',
  },
  {
    icon: 'images/icons/lms.png',
    title: 'LMS (Moodle)',
    text: 'From managing training and educational records to distributing online or blended college courses over the Internet — with features for online collaboration, automated record-keeping and employee registration.',
  },
];
---
<ThemeLayout page="products" heading="Products">

  <section class="inner-page padd-section" style="padding-bottom:0">
    <div class="container">
      <div class="row align-items-center mb-5" data-aos="fade-up">
        <div class="col-md-2 col-sm-12 text-center mb-4 mb-md-0">
          <div class="svc-hero-icon">
            <i class="fa fa-th-large"></i>
          </div>
        </div>
        <div class="col-md-10">
          <h3>Ready-made Solutions Built by Rayinfos</h3>
          <p>Rayinfos Technologies develops and maintains its own product portfolio — from bulk email tools and helpdesk systems to CRM, ecommerce, LMS and live chat solutions — all available as hosted services for your business.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="features" class="padd-section text-center" style="padding-top:0">
    <div class="container" data-aos="fade-up">
      <div class="row" data-aos="fade-up" data-aos-delay="100">
        {products.map((p) => (
          <div class="col-md-6 col-lg-3">
            <div class="feature-block">
              <img src={p.icon} alt={p.title} class="img-fluid">
              <h4>{p.title}</h4>
              <p>{p.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

</ThemeLayout>
